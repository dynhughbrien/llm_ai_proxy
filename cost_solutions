from litellm import completion
from opentelemetry import trace
import sqlalchemy as sa

tracer = trace.get_tracer(__name__)
db = sa.create_engine("postgresql://...")

def call_llm_with_pricing(model: str, messages: list):
    with tracer.start_as_current_span("llm_call") as span:
        # Query DB for pricing
        pricing = db.execute(
            sa.text("SELECT * FROM pricing_models WHERE model_name = :model"),
            {"model": model}
        ).fetchone()
        
        # Make LLM call
        response = completion(model=model, messages=messages)
        
        # Enrich span with cost
        span.set_attribute("gen_ai.model", model)
        span.set_attribute("cost_per_token", pricing.cost_per_token)
        span.set_attribute("litellm.cost", response._hidden_params["response_cost"])
        
        return response
