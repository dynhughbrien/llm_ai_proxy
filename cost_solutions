@Configuration
public class LLMObservabilityConfig {
    
    @Bean
    public LLMInterceptor llmInterceptor(PricingRepository pricingRepository) {
        return new LLMInterceptor(pricingRepository);
    }
}

@Component
class LLMInterceptor {
    
    @Around("@annotation(WithLLMPricing)")
    public Object enrichWithPricing(ProceedingJoinPoint pjp) throws Throwable {
        String model = (String) pjp.getArgs()[0];
        Pricing pricing = pricingRepository.findByModel(model);
        
        Span span = GlobalTracer.get().activeSpan();
        if (span != null) {
            span.setTag("cost_per_token", pricing.getCostPerToken());
        }
        
        return pjp.proceed();
    }
}
